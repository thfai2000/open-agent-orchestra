{
  "name": "@oao/oao-api",
  "version": "1.34.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:worker": "tsx src/workers/workflow-worker.ts",
    "start:controller": "tsx src/workers/controller.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=text-summary --coverage.reporter=html",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/database/seed.ts"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.2.1",
    "@hono/node-server": "^1.13.0",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^0.19.10",
    "@huggingface/transformers": "^4.0.1",
    "@kubernetes/client-node": "^1.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@oao/shared": "*",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.25.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.0",
    "ioredis": "^5.4.0",
    "jose": "^5.10.0",
    "ldapts": "^8.1.7",
    "nodemailer": "^8.0.5",
    "nunjucks": "^3.2.4",
    "pino": "^9.5.0",
    "postgres": "^3.4.0",
    "simple-git": "^3.27.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/nodemailer": "^8.0.0",
    "@types/nunjucks": "^3.2.6",
    "@vitest/coverage-v8": "^2.1.0",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
