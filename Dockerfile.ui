# ── Build Stage ────────────────────────────────────────────────────────────────
FROM node:24-alpine AS builder

WORKDIR /app

# Copy root workspace config + all workspace package.json files
COPY package.json package-lock.json* ./
COPY packages/shared/package.json packages/shared/
COPY packages/ui-base/package.json packages/ui-base/
COPY packages/oao-api/package.json packages/oao-api/
COPY packages/oao-ui/package.json packages/oao-ui/
# Remove lockfile to ensure platform-specific native bindings (oxc-parser) resolve for Alpine
RUN rm -f package-lock.json && npm install

# Copy source (shared + ui-base + oao-ui needed at build time)
COPY packages/shared packages/shared
COPY packages/ui-base packages/ui-base
COPY packages/oao-ui packages/oao-ui
RUN npm run build --workspace=packages/oao-ui

# ── Production Stage ──────────────────────────────────────────────────────────
FROM node:24-alpine AS production

WORKDIR /app

RUN addgroup -S app && adduser -S app -G app

COPY --from=builder /app/packages/oao-ui/.output .output

ENV NODE_ENV=production
ENV NITRO_PORT=3002
EXPOSE 3002

USER app

CMD ["node", ".output/server/index.mjs"]
