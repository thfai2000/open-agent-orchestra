# ── Build Stage ──────────────────────────────────────────────────────────────
FROM node:24-alpine AS builder

WORKDIR /app

# Install root workspace + shared + oao-api deps
COPY package.json package-lock.json* ./
COPY packages/shared/package.json packages/shared/
COPY packages/oao-api/package.json packages/oao-api/
# Remove lockfile to ensure platform-specific native bindings (esbuild) resolve for Alpine
RUN rm -f package-lock.json && npm install --workspace=packages/shared --workspace=packages/oao-api

COPY packages/shared packages/shared
COPY packages/oao-api packages/oao-api

# ── Production Stage ──────────────────────────────────────────────────────────
# Single image for all backend roles: API, Controller, Agent Worker
# Override CMD at runtime to select the role:
#   API:        node --import tsx packages/oao-api/src/server.ts         (default)
#   Controller: node --import tsx packages/oao-api/src/workers/controller.ts
#   Agent:      node --import tsx packages/oao-api/src/workers/agent-worker.ts
FROM node:24-alpine AS production

WORKDIR /app

RUN addgroup -S app && adduser -S app -G app

COPY --from=builder /app/node_modules node_modules
COPY --from=builder /app/packages/shared packages/shared
COPY --from=builder /app/packages/oao-api packages/oao-api
COPY --from=builder /app/package.json .

ENV NODE_ENV=production
ENV AGENT_API_PORT=4002
EXPOSE 4002

USER app

# Default: run the API server
CMD ["node", "--import", "tsx", "packages/oao-api/src/server.ts"]
