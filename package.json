{
  "name": "open-agent-orchestra",
  "version": "1.0.0",
  "private": true,
  "description": "Open Agent Orchestra (OAO) — Autonomous AI workflow engine powered by GitHub Copilot SDK",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=packages/oao-ui & npm run dev --workspace=packages/oao-api",
    "dev:api": "npm run dev --workspace=packages/oao-api",
    "dev:ui": "npm run dev --workspace=packages/oao-ui",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "lint": "eslint packages/*/src/**/*.ts",
    "lint:fix": "eslint packages/*/src/**/*.ts --fix",
    "format": "prettier --write \"packages/*/src/**/*.ts\"",
    "format:check": "prettier --check \"packages/*/src/**/*.ts\"",
    "db:generate": "npm run db:generate --workspace=packages/oao-api",
    "db:push": "npm run db:push --workspace=packages/oao-api",
    "db:seed": "npm run db:seed --workspace=packages/oao-api",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs --outDir ../docs-dist",
    "docs:deploy": "npm run docs:build && cd docs-dist && touch .nojekyll && git init && git checkout -b gh-pages && git add -A && git commit -m 'docs: deploy' && git push -f git@github.com:thfai2000/open-agent-orchestra.git gh-pages && cd -",
    "docs:release": "bash scripts/docs-release.sh",
    "screenshots": "node scripts/screenshots.mjs"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "eslint": "^10.2.0",
    "mermaid": "^11.14.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "shadcn": "^4.1.2",
    "typescript-eslint": "^8.58.0",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17"
  }
}
