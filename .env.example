# =============================================================================
# OAO — Open Agent Orchestra — Environment Configuration
# Autonomous AI workflow engine powered by GitHub Copilot SDK
# =============================================================================

# --- Database ---
AGENT_DATABASE_URL=postgresql://oao:oao_dev@localhost:5432/agent_db
REDIS_URL=redis://localhost:6379

# --- Authentication ---
JWT_SECRET=change-me-to-a-real-64-char-hex-secret-in-production-00000000

# --- Encryption (for stored credentials/tokens) ---
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# --- GitHub Copilot / BYOK model auth ---
GITHUB_TOKEN=
# Optional default for custom provider API key / bearer token auth.
# When unset, custom providers fall back to GITHUB_TOKEN.
DEFAULT_LLM_API_KEY=

# --- Embedding (agent memory semantic search) ---
# Provider: 'local' (default, offline CPU), 'openai', or 'hash' (basic fallback)
EMBEDDING_PROVIDER=local
# Only needed when EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=

# --- Agent Configuration ---
DEFAULT_AGENT_QUOTA=50
DEFAULT_AGENT_MODEL=gpt-4.1
MAX_CONCURRENT_AGENTS=10
DEFAULT_STEP_ALLOCATION_TIMEOUT_SECONDS=300
AGENT_ALLOCATION_RETRY_MS=3000
AGENT_INSTANCE_MAINTENANCE_INTERVAL_MS=3600000
STALE_STATIC_INSTANCE_CLEANUP_MS=86400000

# --- Server ---
AGENT_API_PORT=4002
NODE_ENV=development
LOG_LEVEL=info
PUBLIC_API_BASE_URL=http://localhost:4002
OAO_PLATFORM_API_URL=http://localhost:4002

# --- Docker Hub (for publish.sh) ---
DOCKER_USERNAME=thfai2000

# --- Optional live Jira E2E tests ---
# The Playwright live Jira test creates and deletes one temporary issue.
# Keep real values in your local .env only; never commit them.
RUN_LIVE_JIRA_E2E=0
TESTING_JIRA_BASE_URL=https://your-domain.atlassian.net
TESTING_JIRA_EMAIL=jira-bot@example.com
TESTING_JIRA_API_TOKEN=
TESTING_JIRA_PROJECT_KEY=OAO
TESTING_JIRA_ISSUE_TYPE=Task
