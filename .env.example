# =============================================================================
# OAO — Open Agent Orchestra — Environment Configuration
# Autonomous AI workflow engine powered by GitHub Copilot SDK
# =============================================================================

# --- Database ---
AGENT_DATABASE_URL=postgresql://oao:oao_dev@localhost:5432/agent_db
REDIS_URL=redis://localhost:6379

# --- Authentication ---
JWT_SECRET=change-me-to-a-real-64-char-hex-secret-in-production-00000000

# --- Encryption (for stored credentials/tokens) ---
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# --- GitHub Copilot ---
GITHUB_TOKEN=

# --- Embedding (agent memory semantic search) ---
# Provider: 'local' (default, offline CPU), 'openai', or 'hash' (basic fallback)
EMBEDDING_PROVIDER=local
# Only needed when EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=

# --- Agent Configuration ---
DEFAULT_AGENT_QUOTA=50
DEFAULT_AGENT_MODEL=gpt-4.1
MAX_CONCURRENT_AGENTS=10

# --- Server ---
AGENT_API_PORT=4002
NODE_ENV=development
LOG_LEVEL=info
PUBLIC_API_BASE_URL=http://localhost:4002

# --- Docker Hub (for publish.sh) ---
DOCKER_USERNAME=thfai2000
