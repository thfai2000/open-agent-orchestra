# --- Database ---
AGENT_DATABASE_URL=postgresql://ai_trader:ai_trader_dev@localhost:5432/agent_db
REDIS_URL=redis://localhost:6379

# --- Authentication ---
JWT_SECRET=change-me-to-a-real-64-char-hex-secret-in-production-00000000

# --- Encryption (for stored credentials/tokens) ---
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# --- GitHub Copilot ---
GITHUB_TOKEN=

# --- Agent Configuration ---
DEFAULT_AGENT_QUOTA=50
DEFAULT_AGENT_MODEL=gpt-4.1
