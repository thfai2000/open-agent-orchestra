# OAO — Open Agent Orchestra values template
# Copy to values.yaml and fill in secrets:
#   cp values.yaml.template values.yaml
# values.yaml is .gitignored — NEVER commit real credentials.

namespace: open-agent-orchestra

# Single backend image — command override selects the role (API / Controller / Agent)
coreImage: oao-core:latest

ingress:
  enabled: true
  host: oao.local
  className: nginx
  annotations: {}

api:
  replicas: 2
  port: 4002
  resources:
    requests:
      memory: 256Mi
      cpu: 200m
    limits:
      memory: 512Mi
      cpu: 500m
  hpa:
    enabled: true
    minReplicas: 2
    maxReplicas: 8
    targetCPUUtilization: 70

ui:
  image: oao-ui:latest
  replicas: 1
  port: 3002
  hpa:
    enabled: false
    minReplicas: 1
    maxReplicas: 3
    targetCPUUtilization: 70

controller:
  replicas: 1
  resources:
    requests:
      memory: 128Mi
      cpu: 100m
    limits:
      memory: 256Mi
      cpu: 250m
  hpa:
    enabled: false
    minReplicas: 1
    maxReplicas: 2
    targetCPUUtilization: 70

agentPod:
  resources:
    requests:
      memory: 256Mi
      cpu: 200m
    limits:
      memory: 512Mi
      cpu: 500m

# Static agent worker instances (long-running BullMQ consumers)
agentWorker:
  enabled: true
  replicas: 2
  resources:
    requests:
      memory: 256Mi
      cpu: 200m
    limits:
      memory: 512Mi
      cpu: 500m

redis:
  image: redis:7-alpine
  resources:
    requests:
      memory: 64Mi
      cpu: 100m
    limits:
      memory: 128Mi
      cpu: 250m

postgres:
  image: pgvector/pgvector:pg16
  storage: 5Gi
  resources:
    requests:
      memory: 256Mi
      cpu: 250m
    limits:
      memory: 512Mi
      cpu: 500m

hpa:
  enabled: true
  minReplicas: 2
  maxReplicas: 8
  targetCPUUtilization: 70

config:
  NODE_ENV: production
  LOG_LEVEL: info
  AGENT_API_PORT: "4002"
  PUBLIC_API_BASE_URL: "https://oao.example.local"
  OAO_PLATFORM_API_URL: "http://oao-api:4002"
  MAX_CONCURRENT_AGENTS: "10"
  DEFAULT_AGENT_QUOTA: "50"
  DEFAULT_AGENT_MODEL: "gpt-4.1"
  CONTROLLER_POLL_INTERVAL: "30000"
  EMBEDDING_PROVIDER: "local"

secrets:
  # PostgreSQL password
  POSTGRES_PASSWORD: "CHANGE_ME"
  # OAO DB connection
  AGENT_DATABASE_URL: "postgresql://oao:CHANGE_ME@postgres:5432/agent_db"
  # Redis connection
  REDIS_URL: "redis://redis:6379"
  # JWT secret for this platform
  JWT_SECRET: ""
  # AES-256-GCM encryption key
  ENCRYPTION_KEY: ""
  # GitHub token for Copilot SDK
  GITHUB_TOKEN: ""
